---
import { ui, type Lang } from '../i18n/ui';
import { htmlLang, isRtl, localizedPath, useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const dir = isRtl(lang) ? 'rtl' : 'ltr';

const site = Astro.site ?? new URL('https://airothy.com');
const canonical = new URL(localizedPath(lang), site).href;
// hreflang alternates for every locale + x-default pointing at English.
const alternates = (Object.keys(ui) as Lang[]).map((l) => ({
  hreflang: htmlLang[l],
  href: new URL(localizedPath(l), site).href,
}));
---

<!doctype html>
<html lang={htmlLang[lang]} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t('metaDescription')} />
    <meta name="theme-color" content="#0A1E3D" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/airothy-icon.png" />

    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={new URL('/', site).href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={t('metaTitle')} />
    <meta property="og:description" content={t('metaDescription')} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={htmlLang[lang].replace('-', '_')} />
    <meta property="og:image" content="https://airothy.com/airothy-icon.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <title>{t('metaTitle')}</title>

    <style is:global>
      :root {
        --bg-deep: #08182f;
        --bg: #0a1e3d;
        --bg-card: #122e57;
        --bg-card-hover: #173868;
        --border: rgba(255, 255, 255, 0.09);
        --border-strong: rgba(255, 255, 255, 0.18);
        --text: #f5f8ff;
        --text-muted: rgba(245, 248, 255, 0.62);
        --text-faint: rgba(245, 248, 255, 0.42);
        --accent: #8ab9ff;
        --accent-soft: rgba(138, 185, 255, 0.16);
        --max: 1120px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        background: radial-gradient(circle at 50% -10%, #1b3a6a 0%, var(--bg) 40%, var(--bg-deep) 100%);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', 'Noto Sans',
          'Noto Sans Arabic', 'Noto Sans CJK SC', 'Noto Sans CJK JP', 'Noto Sans CJK KR',
          'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Apple SD Gothic Neo',
          'PingFang SC', 'Microsoft YaHei', 'Inter', system-ui, sans-serif;
        font-size: 17px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        min-height: 100vh;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 120ms ease;
      }

      a:hover {
        color: #b8d4ff;
      }

      .wrap {
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 28px;
      }

      /* ---------- nav ---------- */
      nav {
        padding: 28px 0;
      }

      nav .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .brand img {
        height: 28px;
        width: auto;
        filter: brightness(0) invert(1);
        opacity: 0.95;
      }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 22px;
      }

      .nav-actions a {
        color: var(--text-muted);
        font-size: 15px;
        font-weight: 500;
      }

      .nav-actions a:hover {
        color: var(--text);
      }

      /* ---------- language switcher ---------- */
      .lang-switcher {
        position: relative;
        font-size: 15px;
      }

      .lang-switcher > summary {
        list-style: none;
        cursor: pointer;
        color: var(--text-muted);
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        user-select: none;
      }

      .lang-switcher > summary::-webkit-details-marker {
        display: none;
      }

      .lang-switcher > summary:hover {
        color: var(--text);
      }

      .lang-switcher > summary .chev {
        width: 12px;
        height: 12px;
        opacity: 0.7;
      }

      .lang-menu {
        position: absolute;
        inset-inline-end: 0;
        top: calc(100% + 10px);
        z-index: 20;
        min-width: 168px;
        padding: 6px;
        border-radius: 12px;
        background: var(--bg-card);
        border: 1px solid var(--border-strong);
        box-shadow: 0 18px 40px -16px rgba(0, 0, 0, 0.6);
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .lang-menu a {
        display: block;
        padding: 9px 12px;
        border-radius: 8px;
        color: var(--text-muted);
        font-weight: 500;
      }

      .lang-menu a:hover {
        background: rgba(255, 255, 255, 0.06);
        color: var(--text);
      }

      .lang-menu a[aria-current='true'] {
        color: var(--text);
        background: var(--accent-soft);
      }

      /* ---------- hero ---------- */
      .hero {
        padding: 80px 0 60px;
        text-align: center;
      }

      .hero .badge {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.02em;
        margin-bottom: 28px;
      }

      .hero h1 {
        font-size: clamp(40px, 6vw, 68px);
        line-height: 1.05;
        font-weight: 700;
        letter-spacing: -0.025em;
        margin: 0 auto 22px;
        max-width: 900px;
      }

      .hero h1 .accent {
        background: linear-gradient(135deg, #c9dbff 0%, #6fa1f0 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      .hero p {
        font-size: clamp(17px, 1.6vw, 20px);
        color: var(--text-muted);
        max-width: 640px;
        margin: 0 auto 38px;
        white-space: pre-line;
      }

      .cta-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 13px 22px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        letter-spacing: -0.005em;
        transition: transform 120ms ease, background 120ms ease;
        border: 1px solid transparent;
      }

      .btn-primary {
        background: var(--text);
        color: var(--bg);
      }

      .btn-primary:hover {
        background: #fff;
        transform: translateY(-1px);
      }

      .btn-secondary {
        background: transparent;
        color: var(--text);
        border-color: var(--border-strong);
      }

      .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.06);
        color: var(--text);
      }

      .hero-meta {
        margin-top: 18px;
        font-size: 13px;
        color: var(--text-faint);
      }

      /* ---------- hero visual ---------- */
      .hero-visual {
        margin: 64px auto 0;
        max-width: 520px;
        padding: 36px 28px;
        border-radius: 24px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0) 100%);
        border: 1px solid var(--border);
        text-align: center;
      }

      .hero-visual img {
        width: 180px;
        height: 180px;
        border-radius: 36px;
        box-shadow:
          0 24px 60px -20px rgba(0, 0, 0, 0.6),
          0 0 0 1px rgba(255, 255, 255, 0.08);
      }

      /* ---------- features ---------- */
      section.features {
        padding: 100px 0 40px;
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }

      @media (max-width: 820px) {
        .features-grid {
          grid-template-columns: 1fr;
        }
      }

      .feature {
        padding: 32px 28px;
        border-radius: 18px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        transition: background 160ms ease, transform 160ms ease;
      }

      .feature:hover {
        background: var(--bg-card-hover);
        transform: translateY(-2px);
      }

      .feature .icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: var(--accent-soft);
        color: var(--accent);
        display: grid;
        place-items: center;
        margin-bottom: 18px;
      }

      .feature h3 {
        font-size: 19px;
        font-weight: 700;
        margin: 0 0 10px;
        letter-spacing: -0.01em;
      }

      .feature p {
        margin: 0;
        font-size: 15px;
        color: var(--text-muted);
        line-height: 1.6;
      }

      /* ---------- how-it-works ---------- */
      section.how {
        padding: 80px 0;
      }

      .section-title {
        text-align: center;
        margin-bottom: 56px;
      }

      .section-title h2 {
        font-size: clamp(28px, 3.6vw, 38px);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 12px;
      }

      .section-title p {
        color: var(--text-muted);
        font-size: 17px;
        max-width: 560px;
        margin: 0 auto;
      }

      .steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }

      @media (max-width: 820px) {
        .steps {
          grid-template-columns: 1fr;
        }
      }

      .step {
        padding: 28px 26px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid var(--border);
      }

      .step .n {
        display: inline-block;
        font-variant-numeric: tabular-nums;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--accent);
        margin-bottom: 12px;
      }

      .step h3 {
        margin: 0 0 8px;
        font-size: 17px;
        font-weight: 700;
        letter-spacing: -0.01em;
      }

      .step p {
        margin: 0;
        font-size: 14px;
        color: var(--text-muted);
      }

      /* ---------- privacy ---------- */
      section.privacy {
        padding: 60px 0 80px;
      }

      .privacy-card {
        padding: 36px 36px;
        border-radius: 18px;
        background: var(--bg-card);
        border: 1px solid var(--border);
      }

      .privacy-card h3 {
        margin: 0 0 14px;
        font-size: 20px;
        font-weight: 700;
        letter-spacing: -0.01em;
      }

      .privacy-card ul {
        margin: 0;
        padding-inline-start: 22px;
        color: var(--text-muted);
        font-size: 15px;
        line-height: 1.7;
      }

      .privacy-card li + li {
        margin-top: 6px;
      }

      .privacy-card strong {
        color: var(--text);
        font-weight: 600;
      }

      /* ---------- requirements ---------- */
      .requirements {
        margin-top: 28px;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }

      @media (max-width: 600px) {
        .requirements {
          grid-template-columns: 1fr;
        }
      }

      .req {
        padding: 16px 18px;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.02);
        font-size: 14px;
      }

      .req .label {
        display: block;
        color: var(--text-faint);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 6px;
      }

      .req .value {
        color: var(--text);
        font-weight: 500;
      }

      /* ---------- footer ---------- */
      footer {
        border-top: 1px solid var(--border);
        padding: 36px 0 48px;
        margin-top: 60px;
        color: var(--text-faint);
        font-size: 14px;
      }

      footer .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
      }

      footer .links {
        display: flex;
        gap: 22px;
      }

      footer .links a {
        color: var(--text-muted);
      }

      footer .links a:hover {
        color: var(--text);
      }

      /* ---------- RTL adjustments ---------- */
      [dir='rtl'] .badge,
      [dir='rtl'] .req .label,
      [dir='rtl'] .step .n,
      [dir='rtl'] .hero h1,
      [dir='rtl'] .feature h3,
      [dir='rtl'] .section-title h2 {
        /* Letter-spacing breaks Arabic letter joining; reset it. */
        letter-spacing: normal;
      }
    </style>
  </head>

  <body>
    <slot />
  </body>
</html>